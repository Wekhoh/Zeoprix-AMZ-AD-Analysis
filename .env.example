# Copy this file to `.env` to override any defaults from backend/config.py.
# pydantic-settings reads .env automatically; unknown keys are ignored.

# --- Paths ---
# Default: data/tracker.db (relative to repo root)
DATABASE_URL=sqlite:///data/tracker.db

# --- Server ---
PORT=8000
# Frontend dev server URL (CORS allowlist)
FRONTEND_URL=http://localhost:5173

# --- Backups ---
# Number of backups retained; oldest are pruned automatically
MAX_BACKUPS=10

# --- Suggestion / rule engine thresholds ---
# ACOS above this triggers warnings in the suggestion engine
ACOS_WARNING_THRESHOLD=0.50
# Target ACOS used for auto-bid recommendations
ACOS_TARGET=0.30
# ROAS above this is considered a "scale up" opportunity
ROAS_SCALE_UP_THRESHOLD=3.0
# CTR below this (with enough impressions) is flagged
CTR_WARNING_THRESHOLD=0.002
CTR_MIN_IMPRESSIONS=1000
# Spend above this with 0 orders triggers "zero orders" alert
ZERO_ORDERS_MIN_SPEND=5.0
# CPC above (base_bid * this ratio) is flagged as overpay
CPC_OVERPAY_RATIO=1.5

# --- Budget pacing ---
# Monthly advertising budget in USD. Set to 0 to disable budget monitoring.
MONTHLY_BUDGET=0.0
# Warning triggers when projected month-end spend exceeds this fraction of budget
BUDGET_WARNING_THRESHOLD=0.9

# --- Dashboard "today's action list" thresholds ---
# Stricter than suggestion engine — these must be "needs immediate attention"
DASHBOARD_ACOS_ALERT_THRESHOLD=0.40
DASHBOARD_ROAS_SCALE_UP_THRESHOLD=3.0
